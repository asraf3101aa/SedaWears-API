{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch (build & debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/SedaWears.Presentation/bin/Debug/net10.0/SedaWears.Presentation.dll",
            "args": [],
            "cwd": "${workspaceFolder}/SedaWears.Presentation",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:7070"
            }
        }
    ]
}
